<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="512"
    android:viewportHeight="512">

    <!-- Solid modern dark background -->
    <path
        android:pathData="M0,0 h512 v512 h-512 z"
        android:fillColor="#0D0E11" />

    <!-- Blue backing glow -->
    <path
        android:pathData="M256,256m-180,0a180,180 0,1 1,360 0a180,180 0,1 1,-360 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="256"
                android:centerY="256"
                android:gradientRadius="180"
                android:type="radial">
                <item android:offset="0.0" android:color="#FF0EA5E9" />
                <item android:offset="1.0" android:color="#000284C7" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Swirl 1 (Electric Blue Gradient Band) -->
    <path
        android:pathData="M 256,76 C 355.4,76 436,156.6 436,256 C 436,290 426.6,321.7 410.2,348.8 C 400,320 378,240 330,190 C 290,148 240,126 186,110 C 208.5,88.4 230.8,76 256,76 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="0"
                android:startY="512"
                android:endX="512"
                android:endY="0"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF00C6FF" />
                <item android:offset="1.0" android:color="#FF0072FF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Swirl 2 (Metallic Silver Band 1) -->
    <path
        android:pathData="M 256,76 C 220,76 186,85.6 156.6,102 C 210,130 260,180 290,230 C 330,298 332,380 300,422 C 378,396 436,321.7 436,256 C 436,156.6 355.4,76 256,76 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="0"
                android:startY="0"
                android:endX="512"
                android:endY="512"
                android:type="linear">
                <item android:offset="0.0" android:color="#FFF1F5F9" />
                <item android:offset="0.3" android:color="#FFCBD5E1" />
                <item android:offset="0.7" android:color="#FF94A3B8" />
                <item android:offset="1.0" android:color="#FF64748B" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Swirl 3 (Electric Blue Gradient Band 2) -->
    <path
        android:pathData="M 156.6,102 C 119.3,123 90,156.6 76,198 C 110,210 180,240 220,310 C 255,371 245,418 226,432 C 256,436 280,432 300,422 C 270,390 260,330 226,270 C 190,206 170,140 156.6,102 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="0"
                android:startY="512"
                android:endX="512"
                android:endY="0"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF00C6FF" />
                <item android:offset="1.0" android:color="#FF0072FF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Swirl 4 (Metallic Silver Band 2) -->
    <path
        android:pathData="M 76,198 C 76,230 85.6,260 102,290 C 130,236 180,186 230,156 C 298,116 380,114 422,146 C 396,68 321.7,76 256,76 C 156.6,76 76,156.6 76,198 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="512"
                android:startY="0"
                android:endX="0"
                android:endY="512"
                android:type="linear">
                <item android:offset="0.0" android:color="#FFFFFFFF" />
                <item android:offset="0.5" android:color="#FFE2E8F0" />
                <item android:offset="1.0" android:color="#FF475569" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Translucent highlights -->
    <path
        android:pathData="M 256,76 C 355.4,76 436,156.6 436,256 C 436,270 434.5,283.7 431.6,297 C 410,240 360,160 280,116 C 272,102 264,88.7 256,76 Z"
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.2" />

    <!-- Center circular cut-out defining the 'O' structure -->
    <path
        android:pathData="M256,256m-90,0a90,90 0,1 1,180 0a90,90 0,1 1,-180 0"
        android:fillColor="#0D0E11" />

</vector>
