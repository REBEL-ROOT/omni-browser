<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Share files temporarily decrypted inside the app's cache directory -->
    <cache-path name="decrypted_cache" path="." />
    <!-- Downloaded files saved via saveToPublicDownloads (external files dir) -->
    <external-files-path name="omni_downloads" path="Downloads/OmniDownloads/" />
    <!-- Temp staging area used during download before moving to final destination -->
    <files-path name="temp_downloads" path="temp_downloads/" />
</paths>
