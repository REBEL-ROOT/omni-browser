{
    "manifest_version": 2,
    "name": "Omni Media Grabber",
    "version": "2.1.0",
    "description": "Passively detects video stream URLs for download without blocking playback.",
    "browser_specific_settings": {
        "gecko": {
            "id": "omni-media-grabber@omnibrowser.app"
        }
    },
    "background": {
        "scripts": ["background.js"]
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "run_at": "document_start",
            "all_frames": true
        }
    ],
    "permissions": [
        "webRequest",
        "nativeMessaging",
        "nativeMessagingFromContent",
        "geckoViewAddons",
        "<all_urls>"
    ],
    "web_accessible_resources": ["inject.js"]
}
