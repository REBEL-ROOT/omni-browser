{
    "manifest_version": 2,
    "name": "Omni Media Grabber",
    "version": "1.0.0",
    "description": "Intercepts video stream playlists, blobs, and MSE buffer data for offline download.",
    "background": {
        "scripts": ["background.js"]
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "run_at": "document_start",
            "all_frames": true
        }
    ],
    "permissions": [
        "webRequest",
        "<all_urls>"
    ]
}
