{
    "manifest_version": 2,
    "name": "Omni Universal Copy",
    "version": "1.0.0",
    "description": "Bypasses CSS and JS copy event blocks, forcing universal selection of any page content.",
    "browser_specific_settings": {
        "gecko": {
            "id": "omni-universal-copy@omnibrowser.app"
        }
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "css": ["override.css"],
            "js": ["override.js"],
            "run_at": "document_end",
            "all_frames": true
        }
    ]
}
