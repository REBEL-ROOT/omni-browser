{
  "manifest_version": 2,
  "name": "Omni Ad Blocker",
  "version": "1.0.0",
  "description": "Pre-bundled high-speed ad and tracker blocker extension for Omni Browser.",
  "browser_specific_settings": {
    "gecko": {
      "id": "uBlock0@raymondhill.net"
    }
  },
  "permissions": [
    "<all_urls>",
    "webRequest",
    "webRequestBlocking"
  ],
  "background": {
    "scripts": ["background.js"]
  }
}
