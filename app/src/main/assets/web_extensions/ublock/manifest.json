{
  "manifest_version": 2,
  "name": "Omni Ad Blocker",
  "version": "2.0.0",
  "description": "High-speed ad, tracker, popup and cosmetic blocker built into Omni Browser.",
  "browser_specific_settings": {
    "gecko": {
      "id": "uBlock0@raymondhill.net"
    }
  },
  "permissions": [
    "<all_urls>",
    "webRequest",
    "webRequestBlocking",
    "tabs"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
